# APTRANSCO Dataset Portal — local environment configuration
#
# Real values for THIS machine. Git-ignored; never committed.
#
# IMPORTANT: only list keys you want to set to a real value. The .env loader
# uses setdefault(), so a key present with an EMPTY value (e.g. DJANGO_SECRET_KEY=)
# overrides the code's built-in default with "" — which would, for example, make
# startup abort on an empty SECRET_KEY. Omit a key entirely to keep its default.

# --- Core ------------------------------------------------------------------
DJANGO_DEBUG=True

# --- Database (PostgreSQL) -------------------------------------------------
DJANGO_DB_NAME=data_portal
DJANGO_DB_USER=postgres
DJANGO_DB_PASSWORD=subhash
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=60
